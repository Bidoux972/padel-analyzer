#!/usr/bin/env node
/**
 * PADELANALYZER — MIGRATION IMAGES → SUPABASE STORAGE
 * 
 * Ce script :
 *   1. Lit rackets-db.json
 *   2. Télécharge les images depuis padelful.com
 *   3. Les uploade dans Supabase Storage (bucket "racket-images")
 *   4. Génère rackets-db-migrated.json avec les nouvelles URLs
 * 
 * USAGE :
 *   1. Créer un bucket "racket-images" (public) dans Supabase Dashboard → Storage
 *   2. Mettre ce script + rackets-db.json dans un même dossier
 *   3. node migrate-images-supabase.js
 *   4. Le fichier rackets-db-migrated.json est prêt
 *   5. Remplacer rackets-db.json sur GitHub par rackets-db-migrated.json
 */

const https = require('https');
const http = require('http');
const fs = require('fs');
const path = require('path');

// ─── CONFIGURATION ─────────────────────────────────────────
const SUPABASE_URL = 'https://nvomaxjyhuemdfvhzcbf.supabase.co';
const SUPABASE_SERVICE_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Im52b21heGp5aHVlbWRmdmh6Y2JmIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc3MjA5Mjc2MSwiZXhwIjoyMDg3NjY4NzYxfQ.GTTKlUV4CsjP37HkMIzAo-Za1666FMS7lCVlEHy-Ngg';
const BUCKET = 'racket-images';

const INPUT_FILE = 'rackets-db.json';
const OUTPUT_FILE = 'rackets-db-migrated.json';
// ────────────────────────────────────────────────────────────

function downloadToBuffer(url) {
  return new Promise((resolve, reject) => {
    const client = url.startsWith('https') ? https : http;
    client.get(url, { headers: { 'User-Agent': 'PadelAnalyzer-Migration/1.0' } }, (res) => {
      if (res.statusCode >= 300 && res.statusCode < 400 && res.headers.location) {
        return downloadToBuffer(res.headers.location).then(resolve).catch(reject);
      }
      if (res.statusCode !== 200) {
        return reject(new Error(`HTTP ${res.statusCode} for ${url}`));
      }
      const chunks = [];
      res.on('data', (chunk) => chunks.push(chunk));
      res.on('end', () => resolve(Buffer.concat(chunks)));
      res.on('error', reject);
    }).on('error', reject);
  });
}

function uploadToSupabase(fileName, buffer, contentType) {
  return new Promise((resolve, reject) => {
    const uploadPath = `/storage/v1/object/${BUCKET}/${fileName}`;
    const url = new URL(uploadPath, SUPABASE_URL);

    const options = {
      hostname: url.hostname,
      path: url.pathname,
      method: 'POST',
      headers: {
        'Authorization': `Bearer ${SUPABASE_SERVICE_KEY}`,
        'Content-Type': contentType,
        'Content-Length': buffer.length,
        'x-upsert': 'true',
      },
    };

    const req = https.request(options, (res) => {
      let data = '';
      res.on('data', (chunk) => data += chunk);
      res.on('end', () => {
        if (res.statusCode >= 200 && res.statusCode < 300) {
          resolve(data);
        } else {
          reject(new Error(`Upload failed (${res.statusCode}): ${data}`));
        }
      });
    });
    req.on('error', reject);
    req.write(buffer);
    req.end();
  });
}

function sleep(ms) { return new Promise(r => setTimeout(r, ms)); }

function getContentType(fileName) {
  const ext = path.extname(fileName).toLowerCase();
  const types = { '.png': 'image/png', '.jpg': 'image/jpeg', '.jpeg': 'image/jpeg', '.webp': 'image/webp', '.gif': 'image/gif' };
  return types[ext] || 'image/png';
}

async function main() {
  console.log('🏓 PADELANALYZER — Migration images → Supabase Storage\n');

  // Check service key
  if (SUPABASE_SERVICE_KEY === 'COLLE_TA_SERVICE_ROLE_KEY_ICI') {
    console.error('❌ Ouvre ce fichier et remplace COLLE_TA_SERVICE_ROLE_KEY_ICI par ta clé service_role Supabase');
    console.error('   (Dashboard → Settings → API → service_role key)');
    process.exit(1);
  }

  // Read rackets-db.json
  if (!fs.existsSync(INPUT_FILE)) {
    console.error(`❌ Fichier ${INPUT_FILE} introuvable dans le dossier courant`);
    console.error('   Télécharge-le depuis ton repo GitHub et mets-le ici');
    process.exit(1);
  }

  const rackets = JSON.parse(fs.readFileSync(INPUT_FILE, 'utf8'));
  console.log(`📦 ${rackets.length} raquettes trouvées\n`);

  // Filter rackets with images to migrate
  const toMigrate = rackets.filter(r => r.imageUrl && r.imageUrl.includes('padelful.com'));
  const noImage = rackets.filter(r => !r.imageUrl || r.imageUrl === '');
  const alreadyDone = rackets.filter(r => r.imageUrl && !r.imageUrl.includes('padelful.com') && r.imageUrl !== '');

  console.log(`📸 ${toMigrate.length} images à migrer depuis padelful.com`);
  console.log(`⬜ ${noImage.length} sans image`);
  if (alreadyDone.length > 0) console.log(`✅ ${alreadyDone.length} déjà migrées`);
  console.log('');

  const publicBaseUrl = `${SUPABASE_URL}/storage/v1/object/public/${BUCKET}`;
  let success = 0;
  let failed = 0;

  for (let i = 0; i < toMigrate.length; i++) {
    const racket = toMigrate[i];
    const originalUrl = racket.imageUrl;
    const fileName = path.basename(new URL(originalUrl).pathname);

    process.stdout.write(`[${i + 1}/${toMigrate.length}] ${racket.shortName || racket.name}... `);

    try {
      // Download
      const buffer = await downloadToBuffer(originalUrl);

      // Upload to Supabase Storage
      const contentType = getContentType(fileName);
      await uploadToSupabase(fileName, buffer, contentType);

      // Update URL
      racket.imageUrl = `${publicBaseUrl}/${fileName}`;
      success++;
      console.log(`✅ (${(buffer.length / 1024).toFixed(0)} KB)`);
    } catch (err) {
      failed++;
      console.log(`❌ ${err.message}`);
    }

    // Petit délai pour ne pas surcharger
    if (i % 10 === 9) await sleep(500);
  }

  // Write output
  fs.writeFileSync(OUTPUT_FILE, JSON.stringify(rackets, null, 2), 'utf8');

  console.log('\n════════════════════════════════════════');
  console.log(`✅ Migrées : ${success}`);
  if (failed > 0) console.log(`❌ Échouées : ${failed}`);
  console.log(`📄 Fichier généré : ${OUTPUT_FILE}`);
  console.log('');
  console.log('PROCHAINES ÉTAPES :');
  console.log(`  1. Va sur github.com → ton repo → rackets-db.json`);
  console.log(`  2. Clique "Edit" (icône crayon)`);
  console.log(`  3. Remplace le contenu par celui de ${OUTPUT_FILE}`);
  console.log(`  4. Commit → Vercel redéploie automatiquement`);
  console.log('════════════════════════════════════════');
}

main().catch(err => {
  console.error('💥 Erreur fatale:', err.message);
  process.exit(1);
});
